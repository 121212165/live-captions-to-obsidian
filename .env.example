# Live Captions to Obsidian — Environment Variables
# Copy this file to .env and modify as needed.
# These are Layer 2 in the 4-layer config cascade:
#   CLI args > config file (.live-captions.json) > env vars > defaults
#
# See README.md § Configuration for full details.

# Path to your Obsidian vault (default: $HOME/Documents/Obsidian)
# LIVE_CAPTIONS_VAULT=D:\MyVault

# Subdirectory inside the vault for caption notes (default: notes)
# LIVE_CAPTIONS_DIR=captions

# Window title to look for — match your OS language setting
# (default: 实时字幕 ; use "Live Captions" for English Windows)
# LIVE_CAPTIONS_TITLE=Live Captions

# Window detection polling interval in milliseconds (default: 2000, min: 200)
# LIVE_CAPTIONS_WATCH_INTERVAL=2000

# Caption text extraction polling interval in milliseconds (default: 500, min: 100)
# LIVE_CAPTIONS_CAPTURE_INTERVAL=500
